# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://healthmate-user:YOUR_PASSWORD@healthmate-cluster.xxxxx.mongodb.net/healthmate?retryWrites=true&w=majority

# JWT Secret (koi bhi long random string)
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Frontend URL (Vercel deploy hone ke baad update karna)
FRONTEND_URL=https://healthmate-your-name.vercel.app

# Port (Render automatically set kar deta hai)
PORT=5000
